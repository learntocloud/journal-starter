{
  "name": "Journal API",
  "dockerComposeFile": ["./docker-compose.yml"],
  "features": {
    "ghcr.io/va-h/devcontainers-features/uv": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/",
  "runServices": ["postgres"],
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI"
    }
  }
}
